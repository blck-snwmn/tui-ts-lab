{
  "name": "tui-ts-lab",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "fmt": "oxfmt --write apps/",
    "fmt:check": "oxfmt --check apps/",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --deny-warnings . --fix"
  },
  "devDependencies": {
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0"
  }
}
