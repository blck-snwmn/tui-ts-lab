{
  "name": "tui-ts-lab",
  "private": true,
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "cd apps/sample-react-ink && bun run build",
    "fmt": "oxfmt --write apps/",
    "fmt:check": "oxfmt --check apps/",
    "lint": "oxlint --deny-warnings .",
    "lint:fix": "oxlint --deny-warnings . --fix",
    "typecheck": "cd apps/opentui-diff-viewer && bun run typecheck && cd ../sample-react-ink && bun run typecheck"
  },
  "devDependencies": {
    "oxfmt": "0.58.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0"
  }
}
